<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
  fx:controller="dam.mod.controllers.CambiarPasswordController"
  spacing="15"
  prefWidth="390"
  prefHeight="844"
  style="-fx-padding: 15;"
  alignment="TOP_CENTER">

  <HBox spacing="10" alignment="CENTER_LEFT">
    <Button text="%common.back" onAction="#volver" />
    <Label text="%password.title"
      style="-fx-font-size: 18px; -fx-font-weight: bold;" />
  </HBox>

  <Label fx:id="mensajeLabel"
    style="-fx-text-fill: red;" />

  <PasswordField fx:id="oldPasswordField" promptText="%password.old" />
  <PasswordField fx:id="newPasswordField" promptText="%password.new" />
  <PasswordField fx:id="repeatPasswordField" promptText="%password.repeat" />

  <Button text="%password.update"
    onAction="#cambiarPassword"
    prefWidth="250" />

</VBox>