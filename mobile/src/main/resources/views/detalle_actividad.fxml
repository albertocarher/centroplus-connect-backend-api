<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="dam.mod.controllers.DetalleActividadController"
    spacing="15"
    prefWidth="390"
    prefHeight="844"
    style="-fx-padding: 15;"
    alignment="TOP_CENTER">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="%common.back" onAction="#volver" />
        <Label text="%activity.detail" styleClass="app-subtitle"/>
    </HBox>

    <Label fx:id="mensajeLabel"
        style="-fx-text-fill: red;" />

    <Label fx:id="lblNombre" />
    <Label fx:id="lblTipo" />
    <Label fx:id="lblDuracion" />
    <Label fx:id="lblPrecio" />
    <Label fx:id="lblPlazas" />

    <Button text="%activity.reserve"
        onAction="#reservar"
        prefWidth="200" />

</VBox>