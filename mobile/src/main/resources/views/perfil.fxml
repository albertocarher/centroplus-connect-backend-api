<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
       fx:controller="dam.mod.controllers.PerfilController"
       spacing="15"
       prefWidth="390"
       prefHeight="844"
       style="-fx-padding: 15;">

       <HBox spacing="10" alignment="CENTER_LEFT">
              <Button text="%common.back" onAction="#volver" />
              <Label text="%profile.title"
                     style="-fx-font-size: 18px; -fx-font-weight: bold;" />
       </HBox>

       <VBox spacing="10" alignment="CENTER" style="-fx-padding: 35;">

              <Label text="%profile.name"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblNombre"
                     style="-fx-font-size: 13px;" />

              <Label text="%profile.dni"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblDni"
                     style="-fx-font-size: 13px;" />

              <Label text="%profile.email"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblEmail"
                     style="-fx-font-size: 13px;" />

              <Label text="%profile.phone"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblTelefono"
                     style="-fx-font-size: 13px;" />

              <Label text="%profile.type"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblTipo"
                     style="-fx-font-size: 13px;" />

       </VBox>

       

       <VBox alignment="CENTER" spacing="15" styleClass="menu-container" style="-fx-padding: 15;">
              <Button text="%profile.change.password"
                     onAction="#abrirCambiarPassword"
                     styleClass="menu-button"
                     prefWidth="220" />

              <Button text="%profile.change.email"
                     onAction="#abrirCambiarEmail"
                     styleClass="menu-button"
                     prefWidth="220" />

              <Button text="%profile.change.phone"
                     onAction="#abrirCambiarTelefono"
                     styleClass="menu-button"
                     prefWidth="220" />

              <Button text="%profile.logout"
                     onAction="#cerrarSesion"
                     styleClass="menu-button"
                     prefWidth="220" />
       </VBox>

</VBox>