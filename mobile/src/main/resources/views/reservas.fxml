<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
    fx:controller="dam.mod.controllers.ReservasController"
    prefWidth="390"
    prefHeight="844"
    style="-fx-padding: 15;">

    <top>
        <VBox spacing="15"
            alignment="CENTER">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="%common.back" onAction="#volver" />
                <Label text="%reservations.title" styleClass="app-subtitle"/>
            </HBox>

            <Label fx:id="mensajeLabel" style="-fx-text-fill: red;" />

        </VBox>
    </top>

    <center>
        <ListView fx:id="listaReservas" />
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="10">
            <Button text="%reservations.cancel"
                onAction="#cancelarReserva" />
        </HBox>
    </bottom>

</BorderPane>