<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="dam.mod.controllers.CambiarTelefonoController"
    spacing="15"
    prefWidth="390"
    prefHeight="844"
    style="-fx-padding: 15;"
    alignment="TOP_CENTER">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="%common.back" onAction="#volver" />
        <Label text="%phone.title"
            style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    </HBox>

    <Label fx:id="mensajeLabel"
        style="-fx-text-fill: red;" />

    <TextField fx:id="telefonoField" promptText="%phone.new" />
    <TextField fx:id="repeatTelefonoField" promptText="%phone.repeat" />

    <Button text="%phone.update"
        onAction="#cambiarTelefono"
        prefWidth="250" />

</VBox>