<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dam.mod.controllers.ReservasController"
            prefWidth="390"
            prefHeight="844">

    <top>
    <VBox spacing="5">

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="←" onAction="#volver"/>
            <Label text="Mis reservas"/>
        </HBox>

        <Label fx:id="mensajeLabel" style="-fx-text-fill: red;"/>

    </VBox>
</top>

    <center>
        <ListView fx:id="listaReservas"/>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="10">
            <Button text="Cancelar reserva"
                    onAction="#cancelarReserva"/>
        </HBox>
    </bottom>

</BorderPane>