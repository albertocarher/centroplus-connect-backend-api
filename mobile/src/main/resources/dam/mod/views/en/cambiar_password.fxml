<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
  fx:controller="dam.mod.controllers.CambiarPasswordController"
  spacing="15"
  prefWidth="390"
  prefHeight="844"
  style="-fx-padding: 15;">

  <HBox spacing="10" alignment="CENTER_LEFT">
    <Button text="← Back" onAction="#volver" />
    <Label text="Change password"
      style="-fx-font-size: 18px; -fx-font-weight: bold;" />
  </HBox>

  <PasswordField fx:id="oldPasswordField" promptText="Current password" />
  <PasswordField fx:id="newPasswordField" promptText="New password" />
  <PasswordField fx:id="repeatPasswordField" promptText="Repeat password" />

  <Button text="Update password"
    onAction="#cambiarPassword"
    prefWidth="250" />

</VBox>