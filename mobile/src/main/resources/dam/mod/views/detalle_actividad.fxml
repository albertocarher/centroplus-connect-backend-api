<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dam.mod.controllers.DetalleActividadController"
      spacing="15"
      alignment="CENTER"
      prefWidth="390"
      prefHeight="844"
      style="-fx-padding: 15;">

    <!-- HEADER -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Volver" onAction="#volver"/>
        <Label text="Detalle actividad"/>
    </HBox>

    <!-- INFO -->
    <Label fx:id="lblNombre"/>
    <Label fx:id="lblTipo"/>
    <Label fx:id="lblDuracion"/>
    <Label fx:id="lblPrecio"/>
    <Label fx:id="lblPlazas"/>

    <!-- ACCIÓN -->
    <Button text="Reservar plaza"
            onAction="#reservar"
            prefWidth="200"/>

</VBox>